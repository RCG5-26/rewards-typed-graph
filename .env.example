# Copy to .env: cp .env.example .env
# Shared local dev connection (docker-compose postgres service).
DATABASE_URL=postgresql://rewards:rewards@localhost:5432/rewards_test

# libpq / psql fallbacks (required for live integration test guards)
PGHOST=localhost
PGPORT=5432
PGUSER=rewards
PGPASSWORD=rewards
PGDATABASE=rewards_test

# Opt-in only: uncomment to run live Postgres integration tests (hero gate, seed loader)
# RUN_LIVE_POSTGRES_TESTS=1

# Clerk (identity-only — see docs/adr/0006-clerk-identity-only.md)
# Get these from the Clerk Dashboard → API Keys. Copy to .env.local for Next.js app.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Where Clerk's hosted/custom auth UI lives in this app.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# --- API service (apps/api, spec 07) ---
# Port the Hono API listens on; the Next app points its API base URL here.
API_PORT=8787
# Browser origin allowed by CORS (the Next dev server).
CORS_ORIGIN=http://localhost:3000
# Local-only auth bypass: set to the seeded demo user id to skip Clerk while
# developing the API with curl. Only honored when NODE_ENV !== "production";
# the server ignores it (and warns) in production, so Clerk is always required
# in shared/deployed environments even if this leaks into their env.
# AUTH_DEV_USER_ID=00000000-0000-0000-0000-00000000a001
# Optional: override the python interpreter the hero bridge runs under.
# PYTHON_BIN=python3
